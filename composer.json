{
    "name": "examen/todo-api",
    "description": "Prueba técnica PHP Jr - API REST de Tareas con Mezzio y Doctrine",
    "type": "project",
    "require": {
        "php": "^8.1",
        "mezzio/mezzio": "^3.7",
        "mezzio/mezzio-fastroute": "^3.3",
        "mezzio/mezzio-helpers": "^5.7",
        "laminas/laminas-servicemanager": "^3.18",
        "laminas/laminas-config-aggregator": "^1.13",
        "laminas/laminas-stdlib": "^3.17",
        "laminas/laminas-diactoros": "^3.3",
        "doctrine/orm": "^2.17",
        "doctrine/dbal": "^3.7",
        "psr/cache": "^3.0",
        "symfony/cache": "^6.4"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "roave/security-advisories": "dev-latest"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/App/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "AppTest\\": "test/"
        }
    },
    "scripts": {
        "serve": "php -S 0.0.0.0:8080 -t public/",
        "test": "phpunit"
    }
}
